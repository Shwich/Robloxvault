<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Roblox Vault — Find Your Next Game</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg:#0d0d0f; --surface:#16161a; --surface2:#1e1e24; --border:#2a2a35;
    --accent:#6ee7b7; --accent2:#f472b6; --accent3:#a78bfa; --accent4:#fbbf24;
    --accent5:#f87171; --text:#f0eff4; --muted:#6b6a7a; --tag-bg:#1e1e2e;
  }
  body { background:var(--bg); color:var(--text); font-family:'Syne',sans-serif; min-height:100vh; }

.header { padding:2.5rem 2rem 1.25rem; border-bottom:1px solid var(–border); }
.header h1 { font-size:2.6rem; font-weight:800; letter-spacing:-0.05em; line-height:1; }
.accent-dot { color:var(–accent); }
.tagline { font-size:0.75rem; color:var(–muted); font-family:‘IBM Plex Mono’,monospace; margin-top:0.5rem; }

.search-wrap { padding:1.25rem 2rem 0; }
.search { background:var(–surface2); border:1px solid var(–border); color:var(–text); border-radius:6px; padding:0.6rem 1rem; font-family:‘IBM Plex Mono’,monospace; font-size:0.85rem; width:100%; outline:none; transition:border-color 0.15s; }
.search:focus { border-color:var(–accent); }
.search::placeholder { color:var(–muted); }

.filter-group { padding:0.85rem 2rem; display:flex; flex-wrap:wrap; gap:0.4rem; align-items:center; border-bottom:1px solid var(–border); }
.filter-label { font-size:0.62rem; color:var(–muted); font-family:‘IBM Plex Mono’,monospace; margin-right:0.25rem; min-width:42px; }
.filter-label.gold { color:var(–accent4); }
.filter-label.pink { color:var(–accent5); }
.filter-btn { background:var(–surface2); border:1px solid var(–border); color:var(–muted); border-radius:2rem; padding:0.32rem 0.85rem; font-size:0.73rem; font-family:‘Syne’,sans-serif; cursor:pointer; transition:all 0.15s; font-weight:500; }
.filter-btn:hover { border-color:var(–accent); color:var(–accent); }
.filter-btn.active { background:var(–accent); color:#0d0d0f; border-color:var(–accent); font-weight:700; }
.filter-btn.grind-btn:hover { border-color:var(–accent4); color:var(–accent4); }
.filter-btn.grind-btn.active { background:var(–accent4); border-color:var(–accent4); color:#0d0d0f; }
.filter-btn.brainrot-btn:hover { border-color:var(–accent5); color:var(–accent5); }
.filter-btn.brainrot-btn.active { background:var(–accent5); border-color:var(–accent5); color:#0d0d0f; }
.filter-btn.popular-btn:hover { border-color:#fb923c; color:#fb923c; }
.filter-btn.popular-btn.active { background:#fb923c; border-color:#fb923c; color:#0d0d0f; }

.count { font-size:0.7rem; color:var(–muted); font-family:‘IBM Plex Mono’,monospace; padding:0.65rem 2rem; border-bottom:1px solid var(–border); display:flex; align-items:center; gap:1rem; flex-wrap:wrap; }
.count span { color:var(–accent); font-weight:500; }
.live-indicator { display:flex; align-items:center; gap:0.35rem; font-size:0.65rem; color:var(–muted); }
.live-dot { width:6px; height:6px; border-radius:50%; background:#f87171; display:inline-block; animation:pulse 2s infinite; }

.grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:1px; background:var(–border); }
.card { background:var(–surface); padding:1.4rem; cursor:pointer; transition:background 0.15s; display:flex; flex-direction:column; gap:0.65rem; position:relative; overflow:hidden; }
.card:hover { background:var(–surface2); }
.card-emoji { font-size:2.4rem; line-height:1; }
.card-name { font-size:1rem; font-weight:700; letter-spacing:-0.02em; }
.card-desc { font-size:0.78rem; color:var(–muted); line-height:1.55; font-family:‘IBM Plex Mono’,monospace; }
.card-tags { display:flex; flex-wrap:wrap; gap:0.3rem; margin-top:auto; padding-top:0.5rem; }
.tag { font-size:0.65rem; font-family:‘IBM Plex Mono’,monospace; padding:0.2rem 0.5rem; border-radius:2px; background:var(–tag-bg); border:1px solid var(–border); }
.tag.genre       { color:var(–accent3); border-color:rgba(167,139,250,0.2); }
.tag.vibe        { color:var(–accent);  border-color:rgba(110,231,183,0.2); }
.tag.grind-tag   { color:var(–accent4); border-color:rgba(251,191,36,0.2); }
.tag.brainrot-tag{ color:var(–accent5); border-color:rgba(248,113,113,0.2); }
.players { font-size:0.7rem; color:var(–muted); font-family:‘IBM Plex Mono’,monospace; display:flex; align-items:center; gap:0.35rem; }
.dot { width:6px; height:6px; border-radius:50%; background:var(–accent); display:inline-block; animation:pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.3} }
.visits-display { font-size:0.68rem; color:var(–muted); font-family:‘IBM Plex Mono’,monospace; }
.visits-display.live { color:var(–accent); }

.badge { position:absolute; top:0.85rem; right:0.85rem; font-size:0.6rem; font-weight:700; font-family:‘IBM Plex Mono’,monospace; padding:0.15rem 0.45rem; border-radius:2px; }
.badge.new       { background:var(–accent2); color:#0d0d0f; }
.badge.grind     { background:var(–accent4); color:#0d0d0f; }
.badge.brainrot  { background:var(–accent5); color:#0d0d0f; }
.badge.popular   { background:#fb923c;        color:#0d0d0f; }
.empty { padding:4rem 2rem; text-align:center; color:var(–muted); font-family:‘IBM Plex Mono’,monospace; font-size:0.9rem; grid-column:1/-1; }

.overlay { position:fixed; inset:0; background:rgba(0,0,0,0.88); z-index:200; display:none; align-items:center; justify-content:center; padding:1rem; }
.overlay.open { display:flex; }
.modal { background:var(–surface); border:1px solid var(–border); border-radius:10px; width:100%; max-width:580px; max-height:92vh; overflow-y:auto; position:relative; }
.modal-close { position:absolute; top:1rem; right:1rem; background:var(–surface2); border:1px solid var(–border); color:var(–muted); width:34px; height:34px; border-radius:50%; cursor:pointer; font-size:1rem; display:flex; align-items:center; justify-content:center; transition:all 0.15s; z-index:10; }
.modal-close:hover { color:var(–text); border-color:var(–text); }
.modal-header { padding:1.75rem; border-bottom:1px solid var(–border); display:flex; gap:1.25rem; align-items:flex-start; }
.modal-icon { font-size:3.5rem; flex-shrink:0; background:var(–surface2); width:82px; height:82px; border-radius:14px; display:flex; align-items:center; justify-content:center; border:1px solid var(–border); }
.modal-meta { flex:1; min-width:0; }
.modal-title { font-size:1.5rem; font-weight:800; letter-spacing:-0.03em; line-height:1.1; margin-bottom:0.4rem; }
.modal-dev { font-size:0.72rem; color:var(–muted); font-family:‘IBM Plex Mono’,monospace; margin-bottom:0.6rem; }
.modal-players { font-size:0.75rem; font-family:‘IBM Plex Mono’,monospace; display:flex; align-items:center; gap:0.4rem; color:var(–accent); }
.modal-body { padding:1.75rem; }
.modal-label { font-size:0.63rem; color:var(–muted); font-family:‘IBM Plex Mono’,monospace; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.5rem; }
.modal-desc { font-size:0.86rem; color:var(–text); line-height:1.75; font-family:‘IBM Plex Mono’,monospace; opacity:0.85; margin-bottom:1.25rem; }
.modal-tags { display:flex; flex-wrap:wrap; gap:0.4rem; margin-bottom:1.5rem; }
.modal-tag { font-size:0.7rem; font-family:‘IBM Plex Mono’,monospace; padding:0.3rem 0.75rem; border-radius:3px; background:var(–tag-bg); border:1px solid var(–border); }
.modal-tag.genre       { color:var(–accent3); border-color:rgba(167,139,250,0.2); }
.modal-tag.vibe        { color:var(–accent);  border-color:rgba(110,231,183,0.2); }
.modal-tag.grind-tag   { color:var(–accent4); border-color:rgba(251,191,36,0.2); }
.modal-tag.brainrot-tag{ color:var(–accent5); border-color:rgba(248,113,113,0.2); }
.modal-stats { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(–border); border:1px solid var(–border); border-radius:8px; overflow:hidden; margin-bottom:1.5rem; }
.stat { background:var(–surface2); padding:0.85rem 1.1rem; }
.stat-label { font-size:0.63rem; color:var(–muted); font-family:‘IBM Plex Mono’,monospace; margin-bottom:0.25rem; }
.stat-val { font-size:0.95rem; font-weight:700; color:var(–text); }
.stat-val.live { color:var(–accent); }
.btn-play { width:100%; padding:0.8rem; background:var(–accent); color:#0d0d0f; border:none; border-radius:5px; font-family:‘Syne’,sans-serif; font-size:0.95rem; font-weight:700; cursor:pointer; transition:opacity 0.15s; text-decoration:none; display:block; text-align:center; }
.btn-play:hover { opacity:0.85; }

footer { border-top:1px solid var(–border); padding:1.5rem 2rem; font-size:0.7rem; color:var(–muted); font-family:‘IBM Plex Mono’,monospace; display:flex; justify-content:space-between; flex-wrap:wrap; gap:0.5rem; }

@media(max-width:600px){
.header { padding:1.5rem 1rem 1rem; }
.header h1 { font-size:1.8rem; }
.search-wrap,.filter-group,.count { padding-left:1rem; padding-right:1rem; }
.modal-header { flex-direction:column; }
footer { padding:1rem; }
}
</style>

</head>
<body>

<header class="header">
  <h1>ROBLOX<span class="accent-dot">·</span>VAULT</h1>
  <p class="tagline">// find your next obsession. no robux required.</p>
</header>

<div class="search-wrap">
  <input class="search" id="search" type="text" placeholder="search games, genres, vibes...">
</div>

<div class="filter-group">
  <span class="filter-label">genre:</span>
  <button class="filter-btn active" data-filter="all">all</button>
  <button class="filter-btn" data-filter="obby">obby</button>
  <button class="filter-btn" data-filter="tycoon">tycoon</button>
  <button class="filter-btn" data-filter="roleplay">roleplay</button>
  <button class="filter-btn" data-filter="pvp">pvp</button>
  <button class="filter-btn" data-filter="horror">horror</button>
  <button class="filter-btn" data-filter="simulator">simulator</button>
  <button class="filter-btn" data-filter="adventure">adventure</button>
  <button class="filter-btn" data-filter="military">🪖 military</button>
</div>
<div class="filter-group">
  <span class="filter-label gold">grind:</span>
  <button class="filter-btn grind-btn" data-filter="grind">⚡ grind picks</button>
  <span class="filter-label pink" style="margin-left:0.75rem">brainrot:</span>
  <button class="filter-btn brainrot-btn" data-filter="brainrot">🧠 brainrot</button>
  <span class="filter-label" style="color:#fb923c;margin-left:0.75rem">hot:</span>
  <button class="filter-btn popular-btn" data-filter="popular">🔥 popular</button>
</div>

<div class="count">
  <span>showing <span id="count-num">0</span> games</span>
  <span class="live-indicator"><span class="live-dot"></span>visit counts live via roblox api</span>
</div>

<main class="grid" id="grid"></main>

<div class="overlay" id="overlay" role="dialog" aria-modal="true">
  <div class="modal">
    <button class="modal-close" id="modal-close">✕</button>
    <div class="modal-header">
      <div class="modal-icon" id="modal-icon"></div>
      <div class="modal-meta">
        <div class="modal-title" id="modal-title"></div>
        <div class="modal-dev"   id="modal-dev"></div>
        <div class="modal-players"><span class="dot"></span><span id="modal-players"></span> playing now</div>
      </div>
    </div>
    <div class="modal-body">
      <div class="modal-label">about this game</div>
      <div class="modal-desc" id="modal-desc"></div>
      <div class="modal-tags" id="modal-tags"></div>
      <div class="modal-stats" id="modal-stats"></div>
      <a class="btn-play" id="modal-play" target="_blank" rel="noopener noreferrer">▶ play on roblox</a>
    </div>
  </div>
</div>

<footer>
  <span>// roblox vault — built for the culture</span>
  <span>not affiliated with roblox corporation</span>
</footer>

<script>
