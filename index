  // MILITARY
  { name:"PROJECT APEX",            emoji:"🎯", genre:"military", vibe:"competitive", players:"2k+",   placeId:15509312676,     visits:"10M+",  rating:"91%", maxPlayers:"4",  genre2:"Tactical FPS / Campaign",     dev:"ARCSOFT",                    desc:"Helmet-cam tactical shooter. Mission-driven co-op. Spiritual successor to HELLMET.", fullDesc:"PROJECT APEX is a first-person tactical shooter where everything is experienced through a helmet camera. You and up to 3 players take on a mission-driven campaign covering the history of the TITAN Corporation through genetic experimentation and global crisis. Heavily inspired by Insurgency and HELLMET. Currently in pre-alpha but already exceptionally polished." },
  { name:"Phantom Forces",          emoji:"🔭", genre:"military", vibe:"competitive", players:"25k+",  placeId:292439477,       visits:"1.8B+", rating:"90%", maxPlayers:"32", genre2:"FPS / Team Deathmatch",       dev:"StyLiS Studios",             desc:"The OG Roblox FPS. 10+ years old, still the benchmark for military shooters.",        fullDesc:"Phantom Forces has been the gold standard for Roblox FPS games since 2015. 100+ weapons, multiple game modes, deep customisation, and a skill ceiling that rewards hours of practice. If you've ever played Battlefield or Call of Duty and wanted that on Roblox, this is the closest it gets. Available on PC, mobile, Xbox and PS5." },
