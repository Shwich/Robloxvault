  { name:"Natural Disaster Survival",emoji:"🌪️",genre:"pvp",     vibe:"casual",      players:"50k+",  placeId:189707,          visits:"2B+",   rating:"87%", maxPlayers:"30", genre2:"Survival / Action",           dev:"Stickmasterluke",            desc:"Survive floods, earthquakes and tornadoes. Team chaos optional.",                            fullDesc:"One of Roblox's oldest and most beloved games. Each round, players must survive a randomly selected natural disaster — tornado, flood, earthquake, acid rain. Simple premise, endlessly chaotic execution." },
  { name:"Arsenal",                 emoji:"🎯", genre:"pvp",      vibe:"competitive", players:"60k+",  placeId:286090429,       visits:"5B+",   rating:"89%", maxPlayers:"20", genre2:"First-Person Shooter",        dev:"ROLVe Community",            desc:"Fast-paced gun game. Every kill unlocks a new weapon. Chaotic.",                            fullDesc:"Arsenal is Roblox's answer to gun game mode. Every kill earns you a new weapon, cycling from assault rifles all the way down to a rubber duck — first to finish the rotation wins. The first FPS on Roblox to hit 1 billion visits." },
  { name:"Da Hood",                 emoji:"🌆", genre:"pvp",      vibe:"competitive", players:"80k+",  placeId:2788229376,      visits:"4B+",   rating:"82%", maxPlayers:"25", genre2:"Roleplay / PvP",              dev:"Da Hood Entertainment",      desc:"Street RP with PvP everywhere. Not for the faint of heart.",                                 fullDesc:"Da Hood is a street-themed roleplay game where PvP is everywhere. Rob people, fight rival crews, buy guns and cars, establish dominance. Loud, chaotic, extremely online. Has its own entire subculture. Approach with caution and good ping." },
  { name:"Knockout!",               emoji:"🐧", genre:"pvp",      vibe:"casual",      players:"20k+",  placeId:136764190843219, visits:"200M+", rating:"91%", maxPlayers:"12", genre2:"PvP / Arena Brawler",         dev:"braxworks",                  desc:"Penguins on ice. Push everyone off. You can't see their aim. Pure chaos.",     fullDesc:"Knockout! is a physics-based arena brawler where every player is a penguin on a slippery icy platform. You can't see your opponent's aim or power — you can only predict and react. Last penguin standing wins." },
  { name:"RIVALS",                  emoji:"🎮", genre:"pvp",      vibe:"competitive", players:"150k+", placeId:17625359962,     visits:"2B+",   rating:"93%", maxPlayers:"10", genre2:"FPS / Tactical Shooter",      dev:"Nosniy Games",               desc:"1v1 to 5v5 FPS duels. First to 5 kills wins. Won Best Shooter at RIA25.",    fullDesc:"RIVALS is the most polished competitive FPS on Roblox. Challenge players to 1v1 through 5v5 duels where the first team to 5 kills wins the round. Earn keys to unlock weapons and skins, complete contracts for exclusive rewards, and climb the ranked leaderboards. Won Best Shooter Experience at the 2025 Roblox Innovation Awards. Season 3 — The Fame Season — is live now." },
  { name:"Gunfight Arena",          emoji:"🔫", genre:"pvp",      vibe:"competitive", players:"80k+",  placeId:14518422161,     visits:"500M+", rating:"91%", maxPlayers:"20", genre2:"FPS / Team Deathmatch",       dev:"Gunfight Studio",            desc:"Fast FPS with TDM, KOTH, and flag modes. Updated every Friday.",              fullDesc:"A fast-paced first-person shooter with four modes — Team Deathmatch, King of the Hill, Flag, and Bounty. Build kill streaks to unlock powerful abilities like a radar, forcefield, or grenade launcher. Try to nuke the enemy team. Updated every single Friday without fail. One of the most consistently updated FPS games on the platform." },
