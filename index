const GAMES = [
  // ROLEPLAY
  { name:"Brookhaven RP",           emoji:"🏠", genre:"roleplay", vibe:"chill",       players:"500k+", placeId:4924922222,      visits:"55B+",  rating:"93%", maxPlayers:"18", genre2:"Roleplay / Sandbox",          dev:"Wolfpaq & Obe", isPopular:true,              desc:"Live your best suburban life. Or rob a bank. No judgement.",                                  fullDesc:"Brookhaven RP is a massively multiplayer open-world sandbox where there are zero rules and infinite vibes. Buy a house, adopt a car, become a criminal, start a family — or just drive around being chaotic. No objectives. No win conditions. Just pure unfiltered roleplay with strangers on the internet." },
  { name:"Adopt Me!",               emoji:"🐾", genre:"roleplay", vibe:"chill",       players:"400k+", placeId:920587237,       visits:"45B+",  rating:"91%", maxPlayers:"20", genre2:"Roleplay / Trading",          dev:"Uplift Games",               desc:"Trade pets, build homes, flex your inventory on strangers.",                                  fullDesc:"Adopt Me! started as a simple adoption roleplay and somehow became one of the most-played games in Roblox history. The real draw is the pet ecosystem — hatch eggs, raise pets, trade with other players, and accumulate a collection that other players will genuinely envy. Warning: the rare pet economy is surprisingly cutthroat." },
  { name:"Royale High",             emoji:"👑", genre:"roleplay", vibe:"chill",       players:"80k+",  placeId:735030788,       visits:"8B+",   rating:"90%", maxPlayers:"15", genre2:"Roleplay / Fashion",          dev:"callmehbob",                 desc:"Fairy school, fashion, quests. The aesthetics are immaculate.",                               fullDesc:"A fantasy school roleplay with an emphasis on fashion, socialising, and exploration. Royale High has an absurdly detailed cosmetics system, seasonal events, and a surprisingly engaged community. The halo trading economy is its own entire thing." },
  { name:"Work at a Pizza Place",   emoji:"🍕", genre:"roleplay", vibe:"chill",       players:"25k+",  placeId:192800,          visits:"1.5B+", rating:"85%", maxPlayers:"20", genre2:"Simulator / Roleplay",        dev:"Dued1",                      desc:"The original Roblox job sim. Someone always ignores their role.",                             fullDesc:"A Roblox classic running since 2008. Players take on roles in a pizza restaurant — cashier, cook, delivery driver — and attempt to work as a team. In practice half the server ignores their job and chaos reigns. Strangely fun." },
  { name:"Welcome to Bloxburg",     emoji:"🏡", genre:"roleplay", vibe:"chill",       players:"33k+",  placeId:185655149,       visits:"9.9B+", rating:"88%", maxPlayers:"12", genre2:"Roleplay / Life Sim",         dev:"Coffee Stain Studios",       desc:"Build your dream home, get a job, hang out with friends. The Roblox life sim.", isNew:true, fullDesc:"Welcome to Bloxburg is the definitive life simulation game on Roblox. Build and decorate your own home, work jobs like delivery driver or cashier, level up skills like cooking, drive around town, and roleplay with friends. Got a huge map revamp in June 2025 after a live meteor event destroyed the old city. Went free to play in 2024 after years as a paid game. Nearly 10 billion visits." },
  // PVP
