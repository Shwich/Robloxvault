// ── VISIT COUNT (live via roproxy CORS proxy) ─────────────────────────────────
const visitCache  = {};   // placeId (num) -> formatted string
const universeMap = {};   // placeId (num) -> universeId (num)

function fmt(n) {
  if (n >= 1e12) return (n/1e12).toFixed(1) + 'T';
  if (n >= 1e9)  return (n/1e9).toFixed(1)  + 'B';
  if (n >= 1e6)  return (n/1e6).toFixed(1)  + 'M';
  if (n >= 1e3)  return (n/1e3).toFixed(1)  + 'K';
  return String(n);
}

async function loadVisits(placeIds) {
  try {
    // Step 1 – resolve placeIds we haven't seen yet to universeIds
    const needUniverse = placeIds.filter(id => universeMap[id] === undefined);
    if (needUniverse.length) {
      const chunks = [];
      for (let i = 0; i < needUniverse.length; i += 100)
        chunks.push(needUniverse.slice(i, i + 100));
      for (const chunk of chunks) {
        try {
          const r = await fetch(`https://apis.roproxy.com/universes/v1/places?placeIds=${chunk.join(',')}`);
          if (!r.ok) continue;
          const d = await r.json();
          if (d && d.universeIds)
            for (const item of d.universeIds)
              universeMap[item.placeId] = item.universeId;
        } catch(e) {}
      }
    }

    // Step 2 – fetch visit counts for universeIds we don't have cached yet
    const universeIds = placeIds.map(id => universeMap[id]).filter(Boolean);
    const placeByUniverse = {};
    for (const pid of placeIds) if (universeMap[pid]) placeByUniverse[universeMap[pid]] = pid;

    const needVisits = universeIds.filter(uid => {
      const pid = placeByUniverse[uid];
      return pid !== undefined && visitCache[pid] === undefined;
    });
    if (!needVisits.length) return;

    const chunks = [];
    for (let i = 0; i < needVisits.length; i += 50)
      chunks.push(needVisits.slice(i, i + 50));
    for (const chunk of chunks) {
      try {
        const r = await fetch(`https://games.roproxy.com/v1/games?universeIds=${chunk.join(',')}`);
        if (!r.ok) continue;
        const d = await r.json();
        if (!d || !d.data) continue;
        for (const g of d.data) {
          const pid = placeByUniverse[g.id];
          if (pid !== undefined) visitCache[pid] = fmt(g.visits);
        }
      } catch(e) {}
    }

    refreshVisitUI();
  } catch(e) {}
}

function refreshVisitUI() {
  document.querySelectorAll('[data-pid]').forEach(el => {
    const pid = Number(el.dataset.pid);
    if (visitCache[pid] !== undefined) {
      el.textContent = visitCache[pid] + ' visits';
      el.classList.add('live');
    }
  });
  const mv = document.getElementById('modal-visit');
  if (mv) {
    const pid = Number(mv.dataset.pid);
    if (visitCache[pid] !== undefined) {
      mv.textContent = visitCache[pid];
      mv.classList.add('live');
    }
  }
}

// ── RENDER ────────────────────────────────────────────────────────────────────
let activeFilter = 'all';
let searchTerm   = '';

function render() {
  const grid = document.getElementById('grid');
  const q    = searchTerm;

  const filtered = GAMES.filter(g => {
    if (activeFilter === 'brainrot') return !!g.isBrainrot;
    if (g.isBrainrot) return false;                          // never in other tabs
    if (activeFilter === 'grind')   return !!g.isGrind;
    if (activeFilter === 'popular') return !!g.isPopular;
    const matchGenre  = activeFilter === 'all' || g.genre === activeFilter;
    const matchSearch = !q || g.name.toLowerCase().includes(q) || g.genre.includes(q) || g.vibe.includes(q) || g.desc.toLowerCase().includes(q);
    return matchGenre && matchSearch;
  });

  document.getElementById('count-num').textContent = filtered.length;

  if (!filtered.length) {
    grid.innerHTML = '<div class="empty">no games found — try different filters.</div>';
    return;
  }

  grid.innerHTML = filtered.map(g => {
    const idx   = GAMES.indexOf(g);
    const badge = g.isBrainrot ? '<span class="badge brainrot">BRAINROT</span>'
                : g.isGrind   ? '<span class="badge grind">GRIND</span>'
                : g.isPopular ? '<span class="badge popular">🔥 HOT</span>'
                : g.isNew     ? '<span class="badge new">NEW</span>' : '';
    const cached = visitCache[g.placeId];
    return `
      <article class="card" onclick="openModal(${idx})" tabindex="0" role="button">
        ${badge}
        <div class="card-emoji">${g.emoji}</div>
        <div class="card-name">${g.name}</div>
        <div class="card-desc">${g.desc}</div>
        <div class="players"><span class="dot"></span>${g.players} playing</div>
        <div class="visits-display${cached?' live':''}" data-pid="${g.placeId}">${(cached||g.visits)+' visits'}</div>
        <div class="card-tags">
          <span class="tag genre">${g.genre}</span>
          <span class="tag vibe">${g.vibe}</span>
          ${g.isGrind    ? '<span class="tag grind-tag">grind pick</span>'  : ''}
          ${g.isBrainrot ? '<span class="tag brainrot-tag">brainrot</span>' : ''}
          ${g.isPopular && activeFilter === 'popular' ? '<span class="tag" style="color:#fb923c;border-color:rgba(251,146,60,0.2)">🔥 popular</span>' : ''}
        </div>
      </article>`;
  }).join('');

  loadVisits(filtered.map(g => g.placeId));
}

// ── MODAL ─────────────────────────────────────────────────────────────────────
function openModal(idx) {
  const g = GAMES[idx];
  document.getElementById('modal-icon').textContent    = g.emoji;
  document.getElementById('modal-title').textContent   = g.name;
  document.getElementById('modal-dev').textContent     = 'by ' + g.dev;
  document.getElementById('modal-players').textContent = g.players;
  document.getElementById('modal-desc').textContent    = g.fullDesc;

  document.getElementById('modal-tags').innerHTML = `
    <span class="modal-tag genre">${g.genre2}</span>
    <span class="modal-tag vibe">${g.vibe}</span>
    ${g.isGrind    ? '<span class="modal-tag grind-tag">⚡ grind pick</span>'  : ''}
    ${g.isBrainrot ? '<span class="modal-tag brainrot-tag">🧠 brainrot</span>' : ''}`;

  const cached = visitCache[g.placeId];
  document.getElementById('modal-stats').innerHTML = `
    <div class="stat">
      <div class="stat-label">total visits</div>
      <div class="stat-val${cached?' live':''}" id="modal-visit" data-pid="${g.placeId}">${cached || g.visits}</div>
    </div>
    <div class="stat"><div class="stat-label">rating</div><div class="stat-val">${g.rating}</div></div>
    <div class="stat"><div class="stat-label">max players</div><div class="stat-val">${g.maxPlayers}</div></div>
    <div class="stat"><div class="stat-label">genre</div><div class="stat-val">${g.genre}</div></div>`;

  document.getElementById('modal-play').href = `https://www.roblox.com/games/${g.placeId}`;
  document.getElementById('overlay').classList.add('open');
  document.getElementById('modal-close').focus();
  if (!cached) loadVisits([g.placeId]);
}

function closeModal() { document.getElementById('overlay').classList.remove('open'); }

// ── EVENTS ────────────────────────────────────────────────────────────────────
document.getElementById('modal-close').addEventListener('click', closeModal);
document.getElementById('overlay').addEventListener('click', e => { if (e.target === document.getElementById('overlay')) closeModal(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
document.getElementById('grid').addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') e.target.click(); });
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeFilter = btn.dataset.filter;
    render();
  });
});
document.getElementById('search').addEventListener('input', e => {
  searchTerm = e.target.value.toLowerCase().trim();
  render();
});

// ── INIT ──────────────────────────────────────────────────────────────────────
render();
// Refresh visits every 5 minutes
setInterval(() => loadVisits(GAMES.map(g => g.placeId)), 5 * 60 * 1000);
</script>

